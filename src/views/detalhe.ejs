<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <title>Detalhes da Tarefa</title>
  <link rel="stylesheet" href="/detalhe.css">
</head>

<body>

  <h1>Detalhes da Tarefa</h1>

  <h2>
    <%= tarefa.titulo %>
  </h2>

  <p>

    <strong>Descrição:</strong>

    <%= tarefa.descricao %>

  </p>

  <p>

    <strong>Prioridade:</strong>

    <%= tarefa.prioridade %>

  </p>

  <p>

    <strong>Status:</strong>

    <% if (tarefa.concluida) { %>
      Concluída
    <% } else { %>
       Pendente
    <% } %>

  </p>

  <br>

  <a href="/pagina/tarefas">
    Voltar
  </a>

</body>
</html>